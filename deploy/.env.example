# Application images
DOCKERHUB_NAMESPACE=your-dockerhub-namespace
APP_IMAGE_TAG=latest

# HTTP reverse proxy
APP_HTTP_PORT=80
FRONT_VITE_API_BASE_URL=/api
ADMIN_BASE_PATH=/admin/

# Container timezone
TZ=Asia/Shanghai

# Internal admin ports, loopback by default
ETCD_BIND_IP=127.0.0.1
ETCD_CLIENT_PORT=2379
POSTGRES_BIND_IP=127.0.0.1
POSTGRES_PORT=5432
REDIS_BIND_IP=127.0.0.1
REDIS_PORT=6379
RABBITMQ_BIND_IP=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
KAFKA_BIND_IP=127.0.0.1
KAFKA_EXTERNAL_PORT=9092
KAFKA_EXTERNAL_ADVERTISED_HOST=127.0.0.1

# PostgreSQL
POSTGRES_DB=xiaomaipro
POSTGRES_USER=root
POSTGRES_PASSWORD=123456
POSTGRES_DSN=postgres://root:123456@postgres:5432/xiaomaipro?sslmode=disable&TimeZone=Asia%2FShanghai

# Redis
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# etcd
ETCD_ENDPOINT=etcd:2379

# Kafka
KAFKA_ENABLED=true
KAFKA_ADDR=kafka:19092
KAFKA_TOPIC=xiaomaipro-order-create
KAFKA_GROUP_ID=xiaomaipro-order

# RabbitMQ
RABBITMQ_DEFAULT_USER=root
RABBITMQ_DEFAULT_PASS=123456

# User service
JWT_ACCESS_SECRET=replace-with-your-access-secret
JWT_ACCESS_EXPIRE=7200
JWT_REFRESH_EXPIRE=604800
AES_KEY=0123456789abcdef0123456789abcdef

# Order service
ORDER_RPC_TIMEOUT_MS=70000
ORDER_KEY_PREFIX=xiaomaipro:order
ORDER_PAY_TIMEOUT_MINUTES=15
ORDER_QUEUE_STATUS_TTL_MINUTES=30
ORDER_INVENTORY_TTL_HOURS=48
ORDER_PURCHASE_COUNTER_TTL_HOURS=48
ORDER_REFUND_DEADLINE_HOURS=24
ORDER_AUTO_CANCEL_INTERVAL_SECONDS=30
ORDER_LOCAL_ASYNC_BUFFER=1024
PAY_NOTIFY_SUCCESS_RESULT=success
PAY_MOCK_FORM_TEMPLATE=mock://pay/{order_no}

# Payment service
PAYMENT_RPC_TIMEOUT_MS=60000
PAYMENT_KEY_PREFIX=xiaomaipro:payment
PAY_NOTIFY_FAILURE_RESULT=failure
PAY_DEFAULT_SCENE=order
PAY_DEFAULT_CHANNEL=stripe
PAY_REFUND_DEADLINE_HOURS=24
LOCK_TTL_SECONDS=5
LOCK_RETRY_TIMES=20
LOCK_RETRY_INTERVAL_MILLIS=50
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost/payment/processing
STRIPE_CANCEL_URL=http://localhost/order/list
STRIPE_CURRENCY=cny
STRIPE_PAYMENT_METHOD_PRIMARY=card
STRIPE_CHECKOUT_EXPIRE_MINUTES=30
STRIPE_REQUEST_TIMEOUT_SECONDS=45
