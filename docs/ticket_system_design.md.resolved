        bigint target_id "操作对象ID"
        text detail "操作详情JSON"
        varchar ip "操作IP"
        datetime created_at "操作时间"
    }

    %% ===== 关系定义 =====
    USER ||--o{ TICKET_BUYER : "管理购票人"
