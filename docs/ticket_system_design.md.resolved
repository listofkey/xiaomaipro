    }

    ADMIN_USER {
        bigint id PK "管理员ID"
        varchar username "用户名"
        varchar password_hash "密码哈希"
        varchar real_name "真实姓名"
        varchar phone "手机号"
        tinyint role "角色: 1超级管理员 2运营 3客服"
        tinyint status "状态: 0禁用 1正常"
        datetime created_at "创建时间"
        datetime updated_at "更新时间"
    }

    ADMIN_LOG {
        bigint id PK "日志ID"
        bigint admin_id FK "管理员ID"
        varchar action "操作类型"
